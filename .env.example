# ============================================================
# AI Analyst Trading Bot - Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env!
# ============================================================

# --- Application ---
APP_NAME="AI Analyst Trading Bot"
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production-use-long-random-string

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_analyst_bot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# --- OpenAI / ChatGPT ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.3
OPENAI_MAX_TOKENS=max_tokens
OPENAI_TEMPERATURE=0.1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=3

# --- Anthropic (optional) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_ENABLED=false

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
TELEGRAM_ENABLED=false

# --- Email Alerts ---
EMAIL_SMTP_HOST=smtp-mail.outlook.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-email-password-here
EMAIL_FROM=your-email@example.com
EMAIL_TO=your-email@example.com
EMAIL_ENABLED=false
EMAIL_USE_TLS=true

# --- News APIs ---
url=https://newsdata.io/api/1/latest?
NEWSAPI_KEY=your-newsapi-key-here
NEWSAPI_ENABLED=false

BING_NEWS_API_KEY=your-bing-api-key-here
BING_NEWS_ENABLED=false

# --- YouTube Data API ---
YOUTUBE_API_KEY=your-youtube-api-key-here
YOUTUBE_ENABLED=false

# --- Reddit API ---
REDDIT_CLIENT_ID=your-reddit-client-id-here
REDDIT_CLIENT_SECRET=your-reddit-client-secret-here
REDDIT_USER_AGENT=ai-analyst-bot/0.1
REDDIT_ENABLED=false

# --- Market Data ---
CMC_API_KEY=your-coinmarketcap-api-key-here
CMC_ENABLED=false
COINGECKO_API_KEY=your-coingecko-api-key-here
COINGECKO_ENABLED=true
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key-here
ALPHAVANTAGE_ENABLED=false

# --- Ingestion Scheduler ---
RSS_FETCH_INTERVAL_MINUTES=15
NEWS_FETCH_INTERVAL_MINUTES=10
YOUTUBE_FETCH_INTERVAL_MINUTES=60
SOCIAL_FETCH_INTERVAL_MINUTES=30

# --- Analysis ---
LLM_PROVIDER=openai
LLM_ANALYSIS_ENABLED=true
LLM_BATCH_SIZE=10
LLM_COST_LIMIT_USD_PER_DAY=10.0

# --- Alert Thresholds ---
ALERT_MIN_SENTIMENT_ABS=0.6
ALERT_MIN_IMPACT_SCORE=0.7
ALERT_MIN_NOVELTY_SCORE=0.5
ALERT_MIN_CREDIBILITY_SCORE=0.5
ALERT_BREAKING_THRESHOLD=0.85

# --- Monitor Files ---
MONITOR_KEYWORDS_FILE=monitor/keywords.txt
MONITOR_HASHTAGS_FILE=monitor/hashtags.txt
MONITOR_YOUTUBE_CHANNELS_FILE=monitor/youtube_channels.txt
MONITOR_PODCAST_FEEDS_FILE=monitor/podcast_feeds_resolved.txt
MONITOR_WEBSITE_SOURCES_FILE=monitor/website_sources.txt
MONITOR_NEWS_DOMAINS_FILE=monitor/news_domains.txt
MONITOR_SOCIAL_ACCOUNTS_FILE=monitor/social_accounts.txt
MONITOR_ENTITY_ALIASES_FILE=monitor/entity_aliases.yml
