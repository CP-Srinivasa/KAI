# Application
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_MONITOR_DIR=monitor

# Database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_analyst_bot
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30

# Anthropic (optional)
ANTHROPIC_API_KEY=

# YouTube
YOUTUBE_API_KEY=

# Source ingestion
SOURCE_FETCH_TIMEOUT=15
SOURCE_MAX_RETRIES=3
SOURCE_USER_AGENT=ai-analyst-bot/0.1

# Alerts (Phase 4)
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_HOST=
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_DRY_RUN=true
