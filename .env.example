# Application
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_MONITOR_DIR=monitor

# API Authentication (set a strong random token in production!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable auth in local development.
APP_API_KEY=

# Database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_analyst_bot
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Google Gemini (optional)
GEMINI_API_KEY=

# YouTube Data API
YOUTUBE_API_KEY=

# NewsData.io (optional)
NEWSDATA_API_KEY=

# Source ingestion
SOURCE_FETCH_TIMEOUT=15
SOURCE_MAX_RETRIES=3
SOURCE_USER_AGENT=ai-analyst-bot/0.1

# Operator surface (Telegram bot)
OPERATOR_TELEGRAM_BOT_TOKEN=
OPERATOR_ADMIN_CHAT_IDS=
# TELEGRAM_WEBHOOK_SECRET_TOKEN is injected at bot init time (not yet in SettingsConfig)
# Future: TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Alerts (Sprint 3)
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_HOST=
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_DRY_RUN=true
# Minimum priority score (1–10) to trigger an alert. Default: 7
ALERT_MIN_PRIORITY=7
# Digest mode: accumulate + batch alerts instead of immediate delivery
ALERT_DIGEST_ENABLED=false
ALERT_DIGEST_INTERVAL_MINUTES=60
