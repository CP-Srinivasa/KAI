# Application
# HMAC-SHA256 seal for persisted SignalProvenance (SAT-C-PROV-20260422-001).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Empty value = fail-open (audit rows carry provenance without seal).
ALERT_PROVENANCE_SECRET=
# V8.3 / SAT-C-V8-002 — zero-downtime rotation of ALERT_PROVENANCE_SECRET.
# When set, SignalProvenance.verify_hash accepts BOTH the primary secret and
# this one, so historical rows signed under the old secret remain verifiable
# during the rollover window. Writes always use ALERT_PROVENANCE_SECRET.
# Rollover: set *_NEXT=<old> when promoting a new primary; clear once the
# retention window of old-sealed rows has passed.
ALERT_PROVENANCE_SECRET_NEXT=

APP_ENV=development
APP_LOG_LEVEL=INFO
APP_MONITOR_DIR=monitor

# API Authentication (set a strong random token in production!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable auth in local development.
APP_API_KEY=

# Market data provider for TradingLoop and operator surfaces.
# Supported: coingecko (real), mock (dev/test only).
# CoinGecko free tier: no API key, ~30 req/min.
# CoinGecko paid tier (Lite/Pro): set COINGECKO_API_KEY below.  The adapter
# auto-switches to pro-api.coingecko.com and sends x-cg-pro-api-key.
#   - Lite: 100k calls/mo, 250 req/min
#   - Pro:  higher quotas
APP_MARKET_DATA_PROVIDER=coingecko

# CoinGecko Pro/Lite API key.  Leave empty for free-tier.
# Also accepts APP_COINGECKO_API_KEY if you prefer the prefixed form.
COINGECKO_API_KEY=

# CORS — comma-separated list of allowed origins.
# For local development the defaults below are applied automatically.
# For production: set explicitly and never use wildcards.
# Example: APP_CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Request Governance (Sprint 44)
# Maximum allowed request body size in bytes for POST/PUT/PATCH.
# Requests exceeding this limit receive HTTP 413.  Default: 65536 (64 KiB).
APP_MAX_REQUEST_BODY_BYTES=65536
# Guarded-endpoint rate-limit: max requests per subject per window.  Default: 5.
APP_RATE_LIMIT_PER_WINDOW=5
# Rate-limit sliding window duration in seconds.  Default: 30.
APP_RATE_LIMIT_WINDOW_SECONDS=30.0
# Idempotency replay window in seconds.  Cached responses returned for duplicate
# requests within this window.  Set to 0 to disable.  Default: 300 (5 min).
APP_IDEMPOTENCY_WINDOW_SECONDS=300.0

# Database
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_analyst_bot
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=50
DB_ECHO=false

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=30

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Google Gemini (optional)
GEMINI_API_KEY=

# xAI / Grok (optional, fallback only — D-174 Phase I)
# Activate with XAI_FALLBACK_ENABLED=true; otherwise the provider is imported
# but never instantiated. OpenAI-compatible REST surface at https://api.x.ai/v1.
XAI_API_KEY=
XAI_MODEL=grok-4
XAI_TIMEOUT=30
XAI_FALLBACK_ENABLED=false

# Companion model (optional — local/internal endpoint only)
# Must be localhost or internal; external URLs are rejected at startup.
COMPANION_MODEL_ENDPOINT=

# YouTube Data API
YOUTUBE_API_KEY=

# NewsData.io (optional)
NEWSDATA_API_KEY=

# Source ingestion
SOURCE_FETCH_TIMEOUT=15
SOURCE_MAX_RETRIES=3
SOURCE_USER_AGENT=ai-analyst-bot/0.1

# Operator surface (Telegram bot)
OPERATOR_TELEGRAM_BOT_TOKEN=
OPERATOR_ADMIN_CHAT_IDS=
# Optional: override inline-menu configuration file
# TELEGRAM_MENU_CONFIG_PATH=config/telegram_menu.json
# Webhook HMAC secret — must match the secret registered with Telegram setWebhook.
# Leave empty to disable webhook signature verification (not recommended for production).
# V-8: will be moved into OperatorSettings in a future sprint.
OPERATOR_TELEGRAM_WEBHOOK_SECRET=

# Alerts (Sprint 3)
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_HOST=
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_DRY_RUN=true
# Minimum priority score (1–10) to trigger an alert. Default: 7
ALERT_MIN_PRIORITY=7
# D-182: Priority-tier gate for paper execution.  Only analyses with
# recommended_priority >= this threshold open a paper position.  Default 1
# is a no-op; set to 10 to restrict fills to the high-conviction tier where
# live hit-rate evidence is disjoint from the standard tier (D-149:
# P>=10 = 72.73% on n=55 vs P7-P9 = 29.03% on n=186).  priority=None is
# blocked when threshold>1.
EXECUTION_PAPER_MIN_PRIORITY=1
# --------------------------------------------------------------------------- #
# Reward/risk + risk-budget gates (Sprint 2026-06-02, app/risk/engine.py Gate 10)
# --------------------------------------------------------------------------- #
# Closes the gap proven by env ENV-TG-001275462917-23879-502ef70a (US/USDT 10x,
# leveraged risk 42%, R/R T1 ~0.11) — that signal was only ever stopped by the
# max_open_positions cap; no reward/risk or per-signal risk ceiling existed.
#
# ALL default-OFF (<=0 / unset). Turning them on changes productive gating
# globally — a wrong threshold can starve the book. OPERATOR-SIGN-OFF required.
# Evaluation is fail-closed: an ENABLED gate with missing geometry rejects.
#
# STAGED ROLLOUT: RISK_GATES_MODE = off | audit | enforce (default: audit).
#   audit   = compute would_reject + write artifacts/risk_gate_audit.jsonl, but
#             do NOT block. Evaluate reject-rate via
#             `python -m app.observability.risk_gate_audit` BEFORE enforcing.
#   enforce = block risk-increasing entries (exits always allowed).
# Flip to enforce only after the audit report looks sane — this is the guard
# against silent book-starvation.
# RISK_GATES_MODE=audit
#
# Recommended starting values (uncomment after sign-off). NOTE:
# RISK_MAX_LEVERAGED_RISK_PCT denominator = stop_distance_pct * leverage
# (signal geometry risk), NOT account-equity-at-risk.
# RISK_MIN_RR=0.5                  # min reward/risk on nearest target
# RISK_MIN_AVG_RR=0.8              # min reward/risk averaged over all targets
# RISK_MAX_SIGNAL_RISK_PCT=8.0     # max UN-leveraged stop distance |entry-SL|/entry
# RISK_MAX_LEVERAGED_RISK_PCT=35.0 # max stop distance * leverage (the "Risk 42%")
# RISK_MIN_NET_EDGE_BPS=0.0        # min cost-adjusted edge on nearest target (bps)
# RISK_MIN_TARGET_DISTANCE_PCT=0.3 # nearest target must be >= this far from entry
# Digest mode: accumulate + batch alerts instead of immediate delivery
ALERT_DIGEST_ENABLED=false
ALERT_DIGEST_INTERVAL_MINUTES=60

# Dashboard freshness probe (scripts/freshness_check.py)
# Loopback-only is the default (service truth). Set KAI_FRESHNESS_EXTERNAL_BASE
# to additionally probe the public edge in the same cron run — any external
# DOWN/CRIT then contributes to the overall status, so a Cloudflare Access or
# tunnel break cannot hide behind a green loopback probe (D-212).
# Pi systemd loads this file via EnvironmentFile= so the cron picks it up.
# KAI_FRESHNESS_EXTERNAL_BASE=https://kai-trader.org
# Optional override: dedicated freshness API token. Falls back to APP_API_KEY.
# KAI_FRESHNESS_TOKEN=
# Optional Cloudflare Access service-token headers for the external probe.
# Falls back to CF_ACCESS_CLIENT_ID / CF_ACCESS_CLIENT_SECRET if these unset.
# KAI_FRESHNESS_CF_ACCESS_CLIENT_ID=
# KAI_FRESHNESS_CF_ACCESS_CLIENT_SECRET=
# Comma-separated probe names skipped on the external base. Use for endpoints
# whose external surface enforces user-email auth (D-156d / NEO-F-004) and
# therefore cannot be reached by service-token probes by design — without
# this, overall would permanently read crit on a healthy system.
# KAI_FRESHNESS_EXTERNAL_SKIP=dashboard_quality

# ───────────────────────────────────────────────────────────────────────────
# Source-Intake Exploration sandbox (ADR-0006 / DEC-SRC-EXPLORE-001).
# Isolated, default-off, grey-area research layer. NOT part of the production
# pipeline. Run with: python -m app.exploration.cli run
# ───────────────────────────────────────────────────────────────────────────
# Global gate — without this true, only the network-less dummy probe runs.
EXPLORATION_ENABLED=false
EXPLORATION_TIMEOUT_SECONDS=20
EXPLORATION_MAX_RECORDS_PER_PROBE=50
# Politeness throttle between probe runs in one pass (seconds). Do not lower
# aggressively — DoS-near rates are a hard line (ADR-0006).
EXPLORATION_MIN_REQUEST_INTERVAL_SECONDS=2.0
EXPLORATION_ARTIFACTS_DIR=artifacts/exploration
EXPLORATION_SAMPLE_SYMBOL=BTC
# Watchlist for rich per-symbol indicator snapshots (comma-separated).
EXPLORATION_SAMPLE_SYMBOLS=BTC,ETH,SOL
# Register snapshot probes (access_mode=snapshot): one rich record per symbol.
EXPLORATION_SNAPSHOTS_ENABLED=false
# Compute TA (RSI/SMA/volatility) from OHLC where the source provides it.
EXPLORATION_SNAPSHOT_TA_ENABLED=true
# Opt-in browser-like User-Agent for scrapers (grey-area cloaking). Gets past
# soft bot-blocks (e.g. Messari 429/403 -> 200); does NOT defeat strong walls
# (CoinGecko stays 403). Default-off — never silent.
EXPLORATION_SCRAPE_BROWSER_UA_ENABLED=false

# Per-source enable flags (all default-off; opt in per source).
EXPLORATION_COINGECKO_ENABLED=false
EXPLORATION_COINGECKO_SCRAPE_ENABLED=false
EXPLORATION_COINGLASS_ENABLED=false
EXPLORATION_COINGLASS_SCRAPE_ENABLED=false
EXPLORATION_MESSARI_ENABLED=false
EXPLORATION_MESSARI_SCRAPE_ENABLED=false
EXPLORATION_DUNE_ENABLED=false
EXPLORATION_GLASSNODE_ENABLED=false
EXPLORATION_GLASSNODE_SCRAPE_ENABLED=false
EXPLORATION_COINMARKETCAP_ENABLED=false
EXPLORATION_COINMARKETCAP_SCRAPE_ENABLED=false
EXPLORATION_NANSEN_ENABLED=false
EXPLORATION_NANSEN_SCRAPE_ENABLED=false

# Dune query id is NUMERIC (the number in dune.com/queries/<NNNN>/...), NOT your
# username. If left empty or non-numeric, the probe falls back to a working public
# sample query so Dune is demonstrable out-of-the-box (no execution credits spent).
# Override with your own numeric id to pull your query's cached results.
# EXPLORATION_DUNE_QUERY_ID=4132129

# Per-source API keys (sandbox-scoped; leave empty to run only keyless probes).
EXPLORATION_COINGECKO_API_KEY=
EXPLORATION_COINGLASS_API_KEY=
EXPLORATION_MESSARI_API_KEY=
EXPLORATION_DUNE_API_KEY=
EXPLORATION_GLASSNODE_API_KEY=
EXPLORATION_COINMARKETCAP_API_KEY=
EXPLORATION_NANSEN_API_KEY=
