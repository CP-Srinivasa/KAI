[Unit]
Description=KAI Premium-Pipeline Latency Audit (P2 #11 trigger-watch)
After=kai-server.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kai/ai_analyst_trading_bot
EnvironmentFile=/home/kai/ai_analyst_trading_bot/.env
Environment=PYTHONIOENCODING=utf-8
ExecStart=/home/kai/ai_analyst_trading_bot/.venv/bin/python /home/kai/ai_analyst_trading_bot/scripts/premium_latency_audit.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
