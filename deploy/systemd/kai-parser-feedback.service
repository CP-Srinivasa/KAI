[Unit]
Description=KAI Premium-Channel Parser-Feedback Aggregator (P1 #10)
After=kai-server.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kai/ai_analyst_trading_bot
EnvironmentFile=/home/kai/ai_analyst_trading_bot/.env
Environment=PYTHONIOENCODING=utf-8
ExecStart=/home/kai/ai_analyst_trading_bot/.venv/bin/python /home/kai/ai_analyst_trading_bot/scripts/parser_feedback_aggregator.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
