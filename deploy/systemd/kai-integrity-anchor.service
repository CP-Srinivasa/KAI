[Unit]
Description=KAI L3 Audit-Integrity Anchor (OpenTimestamps, default-off)
After=kai-server.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kai/ai_analyst_trading_bot
EnvironmentFile=/home/kai/ai_analyst_trading_bot/.env
Environment=PYTHONIOENCODING=utf-8
ExecStart=/home/kai/ai_analyst_trading_bot/.venv/bin/python /home/kai/ai_analyst_trading_bot/scripts/integrity_anchor_audit.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
