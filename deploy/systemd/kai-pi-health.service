[Unit]
Description=KAI Pi Post-Cutover Health Digest (7d, one-shot)

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kai/ai_analyst_trading_bot
EnvironmentFile=/home/kai/ai_analyst_trading_bot/.env
Environment=PYTHONIOENCODING=utf-8
ExecStart=/bin/bash /home/kai/ai_analyst_trading_bot/scripts/pi_health_digest.sh
StandardOutput=journal
StandardError=journal
