[Unit]
Description=KAI Pi systemd Timer Health Probe (DS-V-C 2026-05-21)

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kai/ai_analyst_trading_bot
EnvironmentFile=/home/kai/ai_analyst_trading_bot/.env
Environment=PYTHONIOENCODING=utf-8
ExecStart=/bin/bash /home/kai/ai_analyst_trading_bot/scripts/pi_timer_health_probe.sh
StandardOutput=journal
StandardError=journal

