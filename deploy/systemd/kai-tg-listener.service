[Unit]
Description=KAI Telegram Premium-Channel MTProto Listener
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/kai/ai_analyst_trading_bot
EnvironmentFile=/home/kai/ai_analyst_trading_bot/.env
Environment=PYTHONIOENCODING=utf-8
# D-208: ensure logs/ exists and is owned by service-user before systemd
# opens StandardOutput=append: as root.
ExecStartPre=+/bin/bash -c 'mkdir -p /home/kai/ai_analyst_trading_bot/logs && chown -R ubuntu:ubuntu /home/kai/ai_analyst_trading_bot/logs'
ExecStart=/home/kai/ai_analyst_trading_bot/.venv/bin/python -m app.cli.main ingestion telegram-channel run
Restart=always
RestartSec=30
# F2-P3 (2026-05-06): hard cap restart storms.
# RestartSec=30 makes 5 restarts physically take ≥150s, so the
# default StartLimitBurst=5 / StartLimitIntervalSec=10 was already
# unreachable — but explicit windows kill the service after 10
# restarts in 5 min instead of letting it churn silently.
StartLimitIntervalSec=300
StartLimitBurst=10
StandardOutput=append:/home/kai/ai_analyst_trading_bot/logs/telegram_listener.log
StandardError=append:/home/kai/ai_analyst_trading_bot/logs/telegram_listener.err.log
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/kai/ai_analyst_trading_bot

[Install]
WantedBy=multi-user.target
